{
  "name": "fusion-erp",
  "version": "2.7.4-render",
  "description": "Fusion ERP - Otimização para Render",
  "private": true,
  "type": "module",
  "main": "server.mjs",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node --watch server.mjs",
    "check": "node --check server.mjs && node --check scripts/render-smoke-test.mjs",
    "audit:261a": "node scripts/auditoria-261a.mjs",
    "perf:261b": "node scripts/performance-261b.mjs",
    "security:261c": "node scripts/seguranca-261c.mjs",
    "interface:261d": "node scripts/interface-261d.mjs",
    "homologacao": "npm run check && npm run audit:261a && npm run perf:261b && npm run security:261c && npm run interface:261d",
    "piloto": "node scripts/piloto-261e.mjs",
    "release": "npm run homologacao && npm run piloto && node scripts/release-261e.mjs",
    "reset:virgem": "node scripts/resetar-sistema-virgem.mjs",
    "homologar:ativacao-segura": "node scripts/homologar-ativacao-segura-261n.mjs",
    "sync:ativacao-segura": "node scripts/sync-ativacao-segura-261n.mjs",
    "render:check": "node scripts/render-smoke-test.mjs",
    "render:start": "NODE_ENV=production node server.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.53.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.0.5"
  }
}
