PORT=3000
NODE_ENV=development

# Banco local para homologação. Não envia dados ao Supabase.
FUSION_DATABASE_PROVIDER=json
FUSION_JSON_FALLBACK=true
FUSION_MIGRATE_JSON_ON_START=false
FUSION_SYNC_DATA_ON_LOCAL=false
FUSION_REQUIRE_SUPABASE_DATA=false

# Preencha somente na implantação, nunca envie chaves reais ao Git.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATA_BUCKET=fusion-data
SUPABASE_BACKUP_BUCKET=fusion-backups
FUSION_TENANT_ID=academia-piloto
FUSION_DATA_SYNC_MS=5000
FUSION_BACKUP_AUTO=false
FUSION_BACKUP_AUTO_ON_LOCAL=false
FUSION_BACKUP_AUTO_MS=21600000

# Fusion Access Agent (opcional no localhost)
ACCESS_AGENT_ID=
ACCESS_AGENT_TOKEN=
ACCESS_SERVER_URL=http://localhost:3000
ACCESS_AGENT_POLL_MS=1500
HENRY_HOST=
HENRY_PORT=3000
