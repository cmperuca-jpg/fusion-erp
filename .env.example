NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Render persistent disk. Local development can leave this empty.
FUSION_PERSISTENT_DIR=/var/data/fusion

# Trocar em produção caso não use generateValue do Render.
JWT_SECRET=troque-este-segredo

# Opcional: URL pública do Render, preenchida automaticamente pelo Render em alguns ambientes.
RENDER_EXTERNAL_URL=

# Backup Supabase Storage
# Crie um bucket privado no Supabase Storage com este nome.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BACKUP_BUCKET=fusion-backups

# Nome configurável dos arquivos de backup
# Pode ser alterado depois pela API /api/backup/config
FUSION_BACKUP_EMPRESA=FusionERP
BACKUP_NAME_PREFIX=FusionERP
BACKUP_FILE_TEMPLATE={prefixo}_Backup_{data}_{hora}.zip
SUPABASE_BACKUP_FOLDER=backups
