NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Render persistent disk. Local development can leave this empty.
FUSION_PERSISTENT_DIR=/var/data/fusion

# Trocar em produção caso não use generateValue do Render.
JWT_SECRET=troque-este-segredo

# Opcional: URL pública do Render, preenchida automaticamente pelo Render em alguns ambientes.
RENDER_EXTERNAL_URL=

# Backup Supabase Storage
# Crie um bucket privado no Supabase Storage com este nome.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BACKUP_BUCKET=fusion-backups

# Banco transacional principal. Em produção, não permita fallback silencioso para JSON.
FUSION_DATABASE_PROVIDER=supabase
FUSION_SUPABASE_RECORDS_TABLE=fusion_v3_records
FUSION_PERSISTENCE_WRITE_MODE=primary
FUSION_JSON_FALLBACK=false
# Ative somente no primeiro deploy para importar os JSON atuais; a operação é idempotente.
FUSION_MIGRATE_JSON_ON_START=false

# Persistência principal de todos os cadastros e uploads no Supabase Storage.
# Use um identificador diferente para cada academia.
SUPABASE_DATA_BUCKET=fusion-data
FUSION_TENANT_ID=academia-piloto
FUSION_DATA_SYNC_MS=5000
FUSION_REQUIRE_SUPABASE_DATA=true

# Backup completo automático (padrão: a cada 6 horas).
FUSION_BACKUP_AUTO=true
FUSION_BACKUP_AUTO_MS=21600000
FUSION_BACKUP_PART_MB=40
FUSION_BACKUP_RESTORE_MAX_MB=250

# Nome configurável dos arquivos de backup
# Pode ser alterado depois pela API /api/backup/config
FUSION_BACKUP_EMPRESA=FusionERP
BACKUP_NAME_PREFIX=FusionERP
BACKUP_FILE_TEMPLATE={prefixo}_Backup_{data}_{hora}.zip
SUPABASE_BACKUP_FOLDER=backups

# Ponte segura Render -> computador da academia
ACCESS_AGENT_ID=academia-01
ACCESS_AGENT_TOKEN=gere-um-token-longo-e-aleatorio
ACCESS_COMMAND_API_KEY=gere-outra-chave-longa-e-aleatoria
ACCESS_SERVER_URL=https://SEU-SERVICO.onrender.com
ACCESS_AGENT_POLL_MS=1500
HENRY_HOST=10.0.0.236
HENRY_PORT=3000

# Reconhecimento facial. As imagens trafegam apenas enquanto a operação está em curso
# e são processadas pelo CompreFace no computador da academia.
FACIAL_ENABLED=true
# Mantenha false durante a homologação. Troque para true somente após validar o terminal.
FACIAL_RELEASE_ENABLED=false
FACIAL_TERMINAL_TOKEN=gere-um-token-longo-exclusivo-para-o-celular
FACIAL_SIMILARITY_THRESHOLD=0.86
FACIAL_LIVENESS_MIN_YAW=8
FACIAL_TASK_TIMEOUT_MS=35000
